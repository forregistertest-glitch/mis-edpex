rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Default: Allow read for all authenticated users
    // Allow write only for authenticated users
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    // Specific rules for research_records
    match /research_records/{recordId} {
      allow read: if true; // Publicly viewable search
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.token.role == 'admin');
    }

    // Specific rules for audit logs (Append only for most users)
    match /audit_logs/{logId} {
      allow read: if isSignedIn() && (request.auth.token.role == 'admin');
      allow create: if isSignedIn();
      allow update, delete: if false; // Audit logs should not be modified
    }
  }
}
